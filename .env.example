# OpenAI API base URL
OPENAI_API_URL=https://your.ollama.com:11434/v1

# API key injected by nginx into every proxied request
OPENAI_API_KEY=your-api-key-here

# Set to true to log request/response body content (parsed fields and messages) to the nginx error log
LOG_BODY=false

# Set to true to log request/response headers to the nginx error log
LOG_HEADERS=false
